# Database (Neon — app data)
DATABASE_URL=postgresql://user:password@localhost:5432/real_estate_platform

# Database (RDS — ARMLS listing mirror)
RDS_DATABASE_URL=postgresql://user:password@localhost:5432/rlsir_platform

# Redis
REDIS_URL=redis://localhost:6379

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Environment
NODE_ENV=development

# Spark Platform (ARMLS Replication)
SPARK_OAUTH_KEY=
SPARK_OAUTH_SECRET=
SPARK_ACCESS_TOKEN=
SPARK_REFRESH_TOKEN=
SPARK_REPLICATION_URL=https://replication.sparkapi.com/Reso/OData

# MLS Credentials (Bridge — legacy, not currently used)
BRIDGE_API_KEY=
BRIDGE_API_SECRET=
