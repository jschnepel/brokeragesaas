{
  "name": "@platform/armls-token-service",
  "version": "1.0.0",
  "description": "ARMLS Spark API OAuth token lifecycle management — refresh Lambda, consumer utility, and recovery tools",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./lambda": {
      "import": "./dist/refresh-lambda.js",
      "types": "./dist/refresh-lambda.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "seed": "tsx scripts/seed-tokens.ts",
    "handshake": "tsx scripts/handshake.ts",
    "test-refresh": "tsx scripts/test-refresh.ts",
    "setup-infra": "bash scripts/setup-infra.sh"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-sns": "^3.700.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "express": "^5.0.0",
    "@types/express": "^5.0.0",
    "open": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
